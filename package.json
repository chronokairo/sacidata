{
  "name": "sacidata",
  "version": "1.0.0",
  "private": true,
  "description": "SACI Data - monitoramento de igarapés urbanos",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "validate": "node scripts/validate.js",
    "build": "node scripts/build.js",
    "deploy": "node scripts/deploy.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "docker:build": "docker build -t sacidata:local .",
    "docker:up": "docker compose up --build",
    "move-md": "node scripts/move-md-to-docs.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "uuid": "^9.0.0",
    "sanitize-html": "^2.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
